<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    :root {
      --ink: #172033;
      --muted: #687386;
      --line: #d7dde7;
      --paper: #f5f7f8;
      --panel: #ffffff;
      --accent: #176b5b;
      --accent-soft: #d7eee9;
      --ok: #166534;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--paper);
      font: 15px/1.55 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    header {
      padding: 30px max(22px, calc((100vw - 1180px) / 2));
      border-bottom: 1px solid var(--line);
      background: #fff;
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 22px 44px;
    }
    .meta { color: var(--muted); margin: 0 0 8px; }
    h1, h2, h3, p { margin-top: 0; }
    h1 { font-size: 34px; line-height: 1.1; margin-bottom: 0; }
    .mockup {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(280px, .65fr);
      gap: 22px;
      align-items: start;
    }
    .screen-stack, .side-panel, section {
      border: 1px solid var(--line);
      background: var(--panel);
    }
    .screen-stack { padding: 18px; }
    .screen {
      border: 1px solid var(--line);
      margin-bottom: 18px;
      background: #fbfcfd;
    }
    .screen:last-child { margin-bottom: 0; }
    .screen-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--line);
      padding: 10px 12px;
      background: #eef4f3;
    }
    .screen-body {
      display: grid;
      grid-template-columns: 160px minmax(0, 1fr);
      min-height: 210px;
    }
    .rail {
      border-right: 1px solid var(--line);
      padding: 14px;
      background: #f7faf9;
    }
    .wire {
      padding: 16px;
    }
    .wire-block {
      border: 1px solid var(--line);
      background: #fff;
      min-height: 42px;
      margin-bottom: 12px;
      padding: 10px;
    }
    .wire-block.hero { min-height: 72px; }
    .wire-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .wire-action {
      display: inline-block;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: #fff;
      padding: 8px 12px;
      margin: 4px 8px 4px 0;
      font-weight: 700;
    }
    .rail-item {
      border: 1px dashed var(--line);
      background: #fff;
      padding: 8px;
      margin-bottom: 8px;
      color: var(--muted);
    }
    .pill {
      display: inline-block;
      border-radius: 999px;
      background: var(--accent-soft);
      color: #12594d;
      padding: 3px 9px;
      font-size: 12px;
      font-weight: 700;
    }
    .side-panel { padding: 18px; }
    .design-context {
      border-left: 4px solid var(--accent);
      background: var(--accent-soft);
      padding: 14px 16px;
      margin-bottom: 22px;
    }
    section { margin-top: 22px; padding: 20px; }
    ul { margin: 0; padding-left: 20px; }
    li { margin: 7px 0; }
    code {
      border: 1px solid var(--line);
      background: #f5f7f9;
      padding: 1px 5px;
      border-radius: 4px;
    }
    .muted { color: var(--muted); }
    @media (max-width: 860px) {
      main { padding-inline: 16px; }
      header { padding-inline: 16px; }
      .mockup { display: block; }
      .side-panel { margin-top: 18px; }
      .screen-body { display: block; }
      .rail { border-right: 0; border-bottom: 1px solid var(--line); }
      .wire-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <header>
    <p class="meta">{{ stage_label }} lo-fi HTML prototype from {{ source_file }} / {{ project_slug }}</p>
    <h1>{{ title }}</h1>
  </header>
  <main>
    <div class="design-context">
      <h2>Design Direction</h2>
      {% if design_principles %}
      {{ design_principles | markdownish | safe }}
      {% elif ia %}
      {{ ia | markdownish | safe }}
      {% else %}
      <p class="muted">No design direction was found in the design spec.</p>
      {% endif %}
    </div>

    <div class="mockup">
      <div class="screen-stack" aria-label="Prototype screens">
        <h2>Lo-Fi Screens</h2>
        {% for screen in screens %}
        <article class="screen">
          <div class="screen-bar">
            <strong>{{ screen.title }}</strong>
            <span class="pill">{{ screen.eyebrow }}</span>
          </div>
          <div class="screen-body">
            <div class="rail">
              {% for component in screen.components[:3] %}
              <div class="rail-item">{{ component }}</div>
              {% endfor %}
            </div>
            <div class="wire">
              <div class="wire-block hero">{{ screen.title }}</div>
              <div class="wire-grid">
                {% for component in screen.components %}
                <div class="wire-block">{{ component }}</div>
                {% endfor %}
              </div>
              <div>
                {% for interaction in screen.interactions %}
                <span class="wire-action">{{ interaction }}</span>
                {% endfor %}
              </div>
            </div>
          </div>
        </article>
        {% else %}
        <p class="muted">No screens were listed in the source brief.</p>
        {% endfor %}
      </div>
      <aside class="side-panel">
        <h2>Interactions</h2>
        <ul>
          {% for interaction in interactions %}
          <li>{{ interaction }}</li>
          {% else %}
          <li class="muted">No interactions were listed in the source brief.</li>
          {% endfor %}
        </ul>
      </aside>
    </div>

    <section>
      <h2>Questions to Answer</h2>
      <ul>
        {% for question in questions %}
        <li>{{ question }}</li>
        {% else %}
        <li class="muted">No validation questions were listed in the source brief.</li>
        {% endfor %}
      </ul>
    </section>

    <section>
      <h2>Design Tokens Referenced</h2>
      {% if tokens.typography or tokens.colors or tokens.spacing %}
      {% if tokens.typography %}<h3>Typography</h3>{{ tokens.typography | markdownish | safe }}{% endif %}
      {% if tokens.colors %}<h3>Color</h3>{{ tokens.colors | markdownish | safe }}{% endif %}
      {% if tokens.spacing %}<h3>Spacing</h3>{{ tokens.spacing | markdownish | safe }}{% endif %}
      {% else %}
      <p class="muted">No token guidance was found in the design spec.</p>
      {% endif %}
    </section>

    {% for section in prototype_sections %}
    <section>
      <h2>{{ section.title }}</h2>
      {{ section.html | safe }}
    </section>
    {% endfor %}
  </main>
</body>
</html>
