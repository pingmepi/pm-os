<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    :root {
      --ink: #18212f;
      --muted: #657084;
      --line: #d8dee8;
      --paper: #fbfaf7;
      --panel: #ffffff;
      --accent: #0f766e;
      --accent-soft: #d8f3ee;
      --warn: #b45309;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--paper);
      font: 15px/1.55 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    header {
      border-bottom: 1px solid var(--line);
      background: linear-gradient(135deg, #ffffff 0%, #eef8f6 100%);
      padding: 32px max(24px, calc((100vw - 1120px) / 2));
    }
    main {
      display: grid;
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 28px;
      max-width: 1120px;
      margin: 0 auto;
      padding: 28px 24px 44px;
    }
    nav {
      position: sticky;
      top: 20px;
      align-self: start;
      border: 1px solid var(--line);
      background: var(--panel);
      padding: 18px;
    }
    nav a {
      display: block;
      color: var(--muted);
      text-decoration: none;
      padding: 7px 0;
    }
    section {
      border: 1px solid var(--line);
      background: var(--panel);
      margin-bottom: 18px;
      padding: 22px;
    }
    h1, h2, h3, p { margin-top: 0; }
    h1 { margin-bottom: 8px; font-size: 34px; line-height: 1.1; }
    h2 { margin-bottom: 12px; font-size: 20px; }
    h3 { margin-bottom: 8px; font-size: 16px; }
    ul { margin: 0; padding-left: 20px; }
    li { margin: 7px 0; }
    code {
      border: 1px solid var(--line);
      background: #f5f7f9;
      padding: 1px 5px;
      border-radius: 4px;
    }
    .meta { color: var(--muted); margin-bottom: 0; }
    .summary {
      border-left: 4px solid var(--accent);
      background: var(--accent-soft);
      padding: 14px 16px;
      margin-top: 18px;
      max-width: 820px;
    }
    .muted { color: var(--muted); }
    @media (max-width: 820px) {
      main { display: block; padding-inline: 16px; }
      nav { position: static; margin-bottom: 18px; }
      header { padding: 26px 16px; }
    }
  </style>
</head>
<body>
  <header>
    <p class="meta">{{ stage_label }} companion HTML from {{ source_file }} / {{ project_slug }}</p>
    <h1>{{ title }}</h1>
    {% if summary %}
    <div class="summary">{{ summary | markdownish | safe }}</div>
    {% endif %}
  </header>
  <main>
    <nav aria-label="Sections">
      {% for section in sections %}
      <a href="#section-{{ loop.index }}">{{ section.title }}</a>
      {% endfor %}
    </nav>
    <div>
      {% for section in sections %}
      <section id="section-{{ loop.index }}">
        <h2>{{ section.title }}</h2>
        {{ section.html | safe }}
      </section>
      {% endfor %}
    </div>
  </main>
</body>
</html>
